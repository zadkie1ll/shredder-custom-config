{
  "api": {
    "listen": "127.0.0.1:10085",
    "services": [
      "StatsService"
    ],
    "tag": "api"
  },
  "log": {
    "loglevel": "none"
  },
  "burstObservatory": {
    "pingConfig": {
      "timeout": "3s",
      "interval": "5m",
      "sampling": 1,
      "destination": "http://connectivitycheck.gstatic.com/generate_204",
      "connectivity": ""
    },
    "subjectSelector": [
      "DIRECT",
      "WL-0"
    ]
  },
  "dns": {
    "servers": [
      "1.1.1.1",
      "8.8.8.8",
      {
        "address": "77.88.8.8",
        "domains": [
          "geosite:private",
          "geosite:category-ru",
          "domain:monkeyisland.xyz",
          "domain:monkeyisland.space",
          "domain:monkeyisland.online",
          "domain:gstatic.com"
        ],
        "port": 53
      }
    ],
    "queryStrategy": "UseIPv4"
  },
  "policy": {
    "levels": {
      "8": {
        "connIdle": 60,
        "downlinkOnly": 0,
        "handshake": 4,
        "statsUserDownlink": true,
        "statsUserUplink": true,
        "uplinkOnly": 0
      }
    },
    "system": {
      "statsInboundDownlink": true,
      "statsInboundUplink": true,
      "statsOutboundDownlink": true,
      "statsOutboundUplink": true
    }
  },
  "remarks": "{{REMARKS}}",
  "routing": {
    "balancers": [
      {
        "fallbackTag": "LOOP-WL",
        "selector": [
          "DIRECT"
        ],
        "tag": "WL-BALANCER"
      },
      {
        "fallbackTag": "LOOP-01",
        "selector": [
          "WL-01"
        ],
        "tag": "01-FALLBACK"
      },
      {
