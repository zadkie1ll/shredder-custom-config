{
  "api": {
    "listen": "127.0.0.1:10085",
    "services": [
      "StatsService"
    ],
    "tag": "api"
  },
  "log": {
    "loglevel": "warning"
  },
  "burstObservatory": {
    "pingConfig": {
      "timeout": "5s",
      "interval": "30s",
      "sampling": 2,
      "httpMethod": "GET",
      "destination": "https://www.google.com/generate_204",
      "connectivity": ""
    },
    "subjectSelector": [
      "WL-01",
      "WL-02",
      "WL-03",
      "WL-04",
      "WL-05"
    ]
  },
  "dns": {
    "servers": [
      "1.1.1.1",
      "1.0.0.1"
    ],
    "queryStrategy": "UseIP"
  },
  "policy": {
    "levels": {
      "8": {
        "connIdle": 60,
        "downlinkOnly": 0,
        "handshake": 4,
        "statsUserDownlink": true,
        "statsUserUplink": true,
        "uplinkOnly": 0
      }
    },
    "system": {
      "statsInboundDownlink": true,
      "statsInboundUplink": true,
      "statsOutboundDownlink": true,
      "statsOutboundUplink": true
    }
  },
  "remarks": "{{REMARKS}}",
  "routing": {
    "balancers": [
      {
        "tag": "MAIN-BALANCER",
        "selector": [
          "{{ENTRY_NAME}}"
        ]
      },
      {
        "tag": "WL-01-BALANCER",
        "selector": [
          "WL-01"
        ],
        "strategy": {
          "type": "leastPing"
        },
        "fallbackTag": "LOOP-WL-02"
      },
      {
        "tag": "WL-02-BALANCER",
        "selector": [
          "WL-02"
        ],
        "strategy": {
          "type": "leastPing"
        },
        "fallbackTag": "LOOP-WL-03"
      },
      {
        "tag": "WL-03-BALANCER",
        "selector": [
          "WL-03"
        ],
        "strategy": {
          "type": "leastPing"
        },
        "fallbackTag": "LOOP-WL-04"
      },
      {
        "tag": "WL-04-BALANCER",
        "selector": [
          "WL-04"
        ],
        "strategy": {
          "type": "leastPing"
        },
        "fallbackTag": "LOOP-WL-05"
      },
      {
        "tag": "WL-05-BALANCER",
        "selector": [
          "WL-05"
        ],
        "strategy": {
          "type": "leastPing"
        },
        "fallbackTag": "LOOP-WL-01"
      }
    ],
    "rules": [
      {
        "type": "field",
        "protocol": [
          "bittorrent"
        ],
        "outboundTag": "DIRECT"
      },
      {
        "type": "field",
        "network": "udp",
        "port": "443",
        "outboundTag": "BLOCK"
      },
      {
        "type": "field",
        "domain": [
          "geosite:private"
        ],
        "outboundTag": "DIRECT"
      },
      {
        "type": "field",
        "ip": [
          "geoip:private"
        ],
        "outboundTag": "DIRECT"
      },
      {
        "type": "field",
        "inboundTag": [
          "ROUTING-SOCKS"
        ],
        "balancerTag": "WL-01-BALANCER"
      },
      {
        "type": "field",
        "inboundTag": [
          "WL-01-REROUTE"
        ],
        "balancerTag": "WL-01-BALANCER"
      },
      {
        "type": "field",
        "inboundTag": [
          "WL-02-REROUTE"
        ],
        "balancerTag": "WL-02-BALANCER"
      },
      {
        "type": "field",
        "inboundTag": [
          "WL-03-REROUTE"
        ],
        "balancerTag": "WL-03-BALANCER"
      },
      {
        "type": "field",
        "inboundTag": [
          "WL-04-REROUTE"
        ],
        "balancerTag": "WL-04-BALANCER"
      },
      {
        "type": "field",
        "inboundTag": [
          "WL-05-REROUTE"
        ],
        "balancerTag": "WL-05-BALANCER"
      },
      {
        "type": "field",
        "network": "tcp,udp",
        "balancerTag": "MAIN-BALANCER"
      }
    ],
    "domainMatcher": "hybrid",
    "domainStrategy": "IPIfNonMatch"
  },
  "inbounds": [
    {
      "tag": "MIXED",
      "port": 10808,
      "listen": "127.0.0.1",
      "protocol": "mixed",
      "settings": {
        "udp": true
      },
      "sniffing": {
        "enabled": true,
        "routeOnly": true,
        "destOverride": [
          "http",
          "tls",
          "quic"
        ]
      }
    },
    {
      "tag": "HTTP",
      "port": 10809,
      "listen": "127.0.0.1",
      "protocol": "http",
      "settings": {
        "allowTransparent": false
      },
      "sniffing": {
        "enabled": true,
        "routeOnly": true,
        "destOverride": [
          "http",
          "tls",
          "quic"
        ]
      }
    },
    {
      "tag": "ROUTING-SOCKS",
      "port": 10810,
      "listen": "127.0.0.1",
      "protocol": "socks",
      "settings": {
        "udp": true,
        "auth": "noauth"
      },
      "sniffing": {
        "enabled": false,
        "routeOnly": true,
        "destOverride": [
          "http",
          "tls",
          "quic"
        ]
      }
    }
  ],
  "outbounds": [
    {
