{
  "api": {
    "listen": "127.0.0.1:10085",
    "services": [
      "StatsService"
    ],
    "tag": "api"
  },
  "log": {
    "loglevel": "none"
  },
  "burstObservatory": {
    "pingConfig": {
      "timeout": "3s",
      "interval": "5m",
      "sampling": 3,
      "httpMethod": "GET",
      "destination": "https://www.google.com/generate_204",
      "connectivity": ""
    },
    "subjectSelector": [
      "DIRECT",
      "WL-VK",
      "WL-YDX",
      "YOUTUBE"
    ]
  },
  "dns": {
    "servers": [
      "1.1.1.1",
      "8.8.8.8",
      {
        "address": "77.88.8.8",
        "domains": [
          "geosite:private",
          "geosite:category-ru",
          "domain:monkeyisland.xyz",
          "domain:monkeyisland.life",
          "domain:monkeyisland.space",
          "domain:easyemploy.org"
        ],
        "port": 53
      }
    ],
    "queryStrategy": "UseIPv4"
  },
  "policy": {
    "levels": {
      "8": {
        "connIdle": 60,
        "downlinkOnly": 0,
        "handshake": 4,
        "statsUserDownlink": true,
        "statsUserUplink": true,
        "uplinkOnly": 0
      }
    },
    "system": {
      "statsInboundDownlink": true,
      "statsInboundUplink": true,
      "statsOutboundDownlink": true,
      "statsOutboundUplink": true
    }
  },
  "remarks": "{{REMARKS}}",
  "routing": {
    "balancers": [
      {
        "tag": "MAIN-BALANCER",
        "selector": [
          "{{ENTRY_NAME}}"
        ]
      },
      {
        "fallbackTag": "{{ENTRY_NAME}}",
        "selector": [
          "YOUTUBE"
        ],
        "tag": "YOUTUBE-BALANCER"
      },
      {
        "fallbackTag": "LOOP-WL",
        "selector": [
          "DIRECT"
        ],
        "tag": "WL-BALANCER"
      },
      {
        "fallbackTag": "LOOP-VK",
        "selector": [
          "WL-VK"
        ],
        "tag": "VK-FALLBACK"
      },
      {
        "fallbackTag": "DIRECT",
        "selector": [
          "WL-YDX"
        ],
        "tag": "YDX-FALLBACK"
      }
    ],
    "rules": [
      {
        "network": "udp",
        "outboundTag": "BLOCK",
        "port": "443"
      },
      {
        "balancerTag": "WL-BALANCER",
        "inboundTag": [
          "ROUTING-SOCKS"
        ]
      },
      {
        "balancerTag": "VK-FALLBACK",
        "inboundTag": [
          "WL-REROUTE"
        ]
      },
      {
        "balancerTag": "YDX-FALLBACK",
        "inboundTag": [
          "VK-REROUTE"
        ]
      },
      {
        "balancerTag": "MAIN-BALANCER",
        "ip": [
          "1.1.1.1",
          "8.8.8.8"
        ]
      },
      {
        "ip": [
          "77.88.8.8"
        ],
        "outboundTag": "DIRECT"
      },
      {
        "balancerTag": "YOUTUBE-BALANCER",
        "domain": [
          "geosite:youtube",
          "full:www.google.com"
        ]
      },
      {
        "balancerTag": "MAIN-BALANCER",
        "domain": [
          "domain:habr.com",
          "domain:jut.su",
          "4pda"
        ]
      },
      {
        "balancerTag": "MAIN-BALANCER",
        "ip": [
          "108.181.60.0/24"
        ]
      },
      {
        "domain": [
          "geosite:private"
        ],
        "outboundTag": "DIRECT"
      },
      {
        "ip": [
          "geoip:private"
        ],
        "outboundTag": "DIRECT"
      },
      {
        "balancerTag": "WL-BALANCER",
        "domain": [
          "geosite:category-ru"
        ]
      },
      {
        "balancerTag": "WL-BALANCER",
        "network": "tcp",
        "port": "8080"
      },
      {
        "balancerTag": "MAIN-BALANCER",
        "network": "tcp,udp"
      }
    ],
    "domainStrategy": "IPIfNonMatch"
  },
  "inbounds": [
    {
      "tag": "MIXED",
      "port": 10808,
      "listen": "127.0.0.1",
      "protocol": "mixed",
      "settings": {
        "udp": true
      },
      "sniffing": {
        "enabled": true,
        "routeOnly": true,
        "destOverride": [
          "http",
          "tls",
          "quic"
        ]
      }
    },
    {
      "listen": "127.0.0.1",
      "port": 10809,
      "protocol": "http",
      "tag": "HTTP"
    },
    {
      "listen": "127.0.0.1",
      "port": 10810,
      "protocol": "socks",
      "settings": {
        "udp": true
      },
      "sniffing": {
        "destOverride": [
          "http",
          "tls",
          "quic"
        ],
        "enabled": false,
        "routeOnly": true
      },
      "tag": "ROUTING-SOCKS"
    }
