        ],
        "tag": "02-FALLBACK"
      },
      {
        "fallbackTag": "DIRECT",
        "selector": [
          "WL-03"
        ],
        "tag": "03-FALLBACK"
      }
    ],
    "domainStrategy": "IPIfNonMatch",
    "rules": [
      {
        "network": "udp",
        "outboundTag": "BLOCK",
        "port": "443"
      },
      {
